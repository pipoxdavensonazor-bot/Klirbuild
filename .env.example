# ═══════════════════════════════════════════════════════════════
# KlirBuild / KlirlineOS — Variables d'environnement
# Copiez vers .env.local puis configurez sur Netlify
# ═══════════════════════════════════════════════════════════════

# ─── Base de données (obligatoire en production) ───
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── App ───
NEXT_PUBLIC_APP_URL=https://www.klirline.app
BETTER_AUTH_SECRET=changez-moi-32-caracteres-minimum
DEMO_AUTH_BYPASS=false

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# ─── Cron Netlify (automations) ───
CRON_SECRET=changez-moi-cron-secret-long

# ─── Marketing Zernio (publication multi-réseaux) ───
ZERNIO_API_KEY=sk_...
ZERNIO_API_BASE_URL=https://zernio.com/api/v1
KLIRLINE_MARKETING_HUB_URL=https://www.klirline.ca

# ─── Google OAuth (connexion) ───
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── Email Resend ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@votredomaine.com
# Webhook inbound (événement email.received) — secret Svix depuis Resend Dashboard
RESEND_WEBHOOK_SECRET=whsec_...

# ─── Klir AI ───
OPENAI_API_KEY=sk-...

# --- Centre d'aide / tutoriels vidéo (Loom) ---
# Public App ID from https://dev.loom.com (SDK Standard). Allow domain klirline.app
NEXT_PUBLIC_LOOM_PUBLIC_APP_ID=
# Optional: Loom/YouTube share URLs for each tutorial (1=bienvenue … 9=abonnement)
NEXT_PUBLIC_HELP_VIDEO_1=
NEXT_PUBLIC_HELP_VIDEO_2=
NEXT_PUBLIC_HELP_VIDEO_3=
NEXT_PUBLIC_HELP_VIDEO_4=
NEXT_PUBLIC_HELP_VIDEO_5=
NEXT_PUBLIC_HELP_VIDEO_6=
NEXT_PUBLIC_HELP_VIDEO_7=
NEXT_PUBLIC_HELP_VIDEO_8=
NEXT_PUBLIC_HELP_VIDEO_9=
