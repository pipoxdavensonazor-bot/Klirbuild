# ─── Core (requis prod) ───────────────────────────────────────────
DATABASE_URL=
BETTER_AUTH_SECRET=
DEMO_AUTH_BYPASS=false
NEXT_PUBLIC_APP_URL=https://klirline.app

# ─── Billing Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_BUSINESS_YEARLY=
# STRIPE_ALLOW_LIVE=true

# Cron Workers (Bearer) — wrangler secret put CRON_SECRET
# Automations + factures récurrentes (/api/cron/*)
CRON_SECRET=

# ─── Courriel Resend ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=billing@klirline.ca
# Adresses dédiées entreprises (ex. slug@inbox.klirline.ca).
# Gratuit sans Resend Pro : garder ce domaine côté produit + forward Cloudflare
# Email Routing (catch-all inbox.*) → klirbuild@estabronae.resend.app
# (domaine Resend managé Free). Le webhook lit aussi received_for.
INBOUND_EMAIL_DOMAIN=inbox.klirline.ca
# Destination Resend Free (reçois les forwards Cloudflare / tests inbound)
RESEND_MANAGED_INBOUND_ADDRESS=klirbuild@estabronae.resend.app

# Cloudflare Workers / OpenNext (voir DEPLOY-CLOUDFLARE.md)
# UPLOADS_KV_ENABLED=true
# CLOUDFLARE_DB_PUSH=1

ZERNIO_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Visio native + live (Daily.co)
DAILY_API_KEY=
NEXT_PUBLIC_DAILY_DOMAIN=klirbuild.daily.co
# DAILY_WEBHOOK_SECRET=  # optionnel pour /api/daily/webhook
# COMPANY_INBOX_EMAIL=

# ─── Centre d'aide (URLs Loom partageables) ───────────────────────
# NEXT_PUBLIC_HELP_VIDEO_1=
# NEXT_PUBLIC_HELP_VIDEO_2=
# NEXT_PUBLIC_LOOM_PUBLIC_APP_ID=
