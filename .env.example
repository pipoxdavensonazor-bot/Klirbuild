# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/klirline?sslmode=require"

# Auth (sessions signées — remplacer par Clerk/Better Auth si besoin)
# Connexion obligatoire par défaut. Mettre "true" UNIQUEMENT pour une démo locale sans login.
DEMO_AUTH_BYPASS="false"
BETTER_AUTH_SECRET="replace-with-long-random-string-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe — NEVER commit real keys. Use .env.local only.
# Prefer TEST keys (sk_test_… / rk_test_…) while developing.
# If a LIVE key was shared in chat, revoke it in the Stripe Dashboard immediately.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Only set in production when intentionally charging real cards:
# STRIPE_ALLOW_LIVE="true"

# Create Products + Prices in Stripe Dashboard, then paste price_… IDs:
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_GROWTH_YEARLY=""
STRIPE_PRICE_BUSINESS_YEARLY=""

# OpenAI
OPENAI_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Courriel (soumissions, factures, boîte entreprise)
# Resend: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="billing@klirline.ca"
COMPANY_INBOX_EMAIL="Contact@klirline.ca"
