# KlirBuild / KlirlineOS — variables d'environnement

# Base de données (obligatoire en production)
DATABASE_URL=postgresql://user:pass@host:5432/klirbuild

# Auth sessions
BETTER_AUTH_SECRET=change-me-long-random-string
DEMO_AUTH_BYPASS=false

# URL publique de l'app
NEXT_PUBLIC_APP_URL=https://www.klirline.app

# Stripe (abonnements SaaS)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
STRIPE_ALLOW_LIVE=false

# OpenAI — Klir AI / IA Chantier
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Resend — courriels transactionnels
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@votredomaine.com
COMPANY_INBOX_EMAIL=inbox@votredomaine.com

# Cron automations (optionnel)
CRON_SECRET=change-me-cron-secret
