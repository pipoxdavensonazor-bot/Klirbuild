# Copy to `.dev.vars` for local `next dev` / `wrangler` previews.
# Never commit real secrets.

NEXTJS_ENV=development
UPLOADS_R2_ENABLED=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

