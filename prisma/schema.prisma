generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  PROJECT_MANAGER
  SITE_SUPERVISOR
  FOREMAN
  FIELD_WORKER
  ESTIMATOR
  ACCOUNTANT
  PAYROLL_CLERK
  SAFETY_OFFICER
  HR_MANAGER
  PROCUREMENT
  OFFICE_ADMIN
  MANAGER
  EMPLOYEE
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum Plan {
  starter
  growth
  business
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  email              String?
  phone              String?
  website            String?
  marketRegion       String             @default("CA-QC")
  plan               Plan               @default(starter)
  subscriptionStatus SubscriptionStatus @default(trialing)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  trialEndsAt        DateTime?
  enabledModules     String[]           @default([])
  brandingPrimary    String             @default("#004F6E")
  brandingAccent     String             @default("#D4AF37")
  logoUrl            String?
  emailFrom          String?
  inboxEmail         String?
  emailSenderName    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  invitations        Invitation[]
  clients            Client[]
  leads              Lead[]
  deals              Deal[]
  quotes             Quote[]
  invoices           Invoice[]
  recurringInvoices  RecurringInvoice[]
  payments           Payment[]
  projects           Project[]
  documents          Document[]
  folders            Folder[]
  automations        Automation[]
  chatThreads        ChatThread[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  emailMessages      EmailMessage[]
  notifications      Notification[]
  constructionWorkspace ConstructionWorkspace?
  constructionJobs              ConstructionJob[]
  constructionLeads             ConstructionLead[]
  constructionEstimates         ConstructionEstimate[]
  constructionChangeOrders        ConstructionChangeOrder[]
  constructionProgressInvoices    ConstructionProgressInvoice[]
  constructionCcqWorkers          ConstructionCcqWorker[]
  constructionCcqDeclarations     ConstructionCcqDeclaration[]
  constructionMarketingCampaigns  ConstructionMarketingCampaign[]
  socialAccounts     SocialAccountConnection[]
  socialCampaigns    SocialAdCampaignRecord[]
  zernioProfileId    String?
  payrollDefaultsJson Json?
  employees          EmployeeProfile[]
  meetings           Meeting[]
  liveSessions       LiveSession[]
  feedPosts          FeedPost[]
  deleteRequests     DeleteRequest[]
  companyBackups     CompanyBackup[]
}

model User {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String    @unique
  emailVerified DateTime?
  passwordHash String?
  role         Role      @default(EMPLOYEE)
  image        String?
  // TOTP 2FA (secret chiffré au repos)
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  accounts     Account[]

  @@index([companyId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?

  @@unique([provider, providerAccountId])
}

model Invitation {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email     String
  role      Role     @default(EMPLOYEE)
  token     String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model SocialAccountConnection {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platform    String
  accountName String
  handle      String
  status      String   @default("disconnected")
  adAccountId String?
  currency    String   @default("CAD")
  followers   Int?
  managedBy   String   @default("zernio")
  klirlineRef String?
  zernioAccountId String?
  connectedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaigns   SocialAdCampaignRecord[]

  @@unique([companyId, platform])
  @@index([companyId, status])
}

model SocialAdCampaignRecord {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountId   String
  account     SocialAccountConnection @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  platform    String
  objective   String   @default("leads")
  status      String   @default("draft")
  dailyBudget Decimal  @default(0) @db.Decimal(12, 2)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  zernioPostId String?
  content     String?
  scheduledFor DateTime?
  publishMode String?
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
}

model Client {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  phone         String?
  status        String   @default("lead")
  tags          String[] @default([])
  city          String?
  industry      String?
  ownerName     String?
  lifetimeValue Decimal  @default(0) @db.Decimal(12, 2)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quotes        Quote[]
  invoices      Invoice[]
  recurringInvoices RecurringInvoice[]
  projects      Project[]
  emailMessages EmailMessage[]

  @@index([companyId, status, createdAt])
}

model EmailMessage {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  direction  String   @default("outbound")
  fromEmail  String
  toEmail    String
  subject    String
  bodyText   String?
  bodyHtml   String?
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  quoteId    String?
  invoiceId  String?
  providerId String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, clientId])
  @@index([companyId, direction])
}

model Lead {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  source    String?
  status    String   @default("new")
  score     Int      @default(0)
  ownerName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
}

model Deal {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title      String
  clientName String?
  value      Decimal  @default(0) @db.Decimal(12, 2)
  stage      String   @default("new")
  ownerName  String?
  closeDate  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, stage])
}

model Quote {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?     @relation(fields: [clientId], references: [id])
  number     String
  status     String      @default("draft")
  currency   String      @default("CAD")
  subtotal   Decimal     @default(0) @db.Decimal(12, 2)
  tax        Decimal     @default(0) @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @default(0) @db.Decimal(12, 2)
  issueDate  DateTime    @default(now())
  validUntil DateTime?
  items      QuoteItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  unit        String?
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
}

model Invoice {
  id                     String        @id @default(cuid())
  companyId              String
  company                Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId               String?
  client                 Client?       @relation(fields: [clientId], references: [id])
  number                 String
  status                 String        @default("draft")
  currency               String        @default("CAD")
  subtotal               Decimal       @default(0) @db.Decimal(12, 2)
  tax                    Decimal       @default(0) @db.Decimal(12, 2)
  discount               Decimal       @default(0) @db.Decimal(12, 2)
  total                  Decimal       @default(0) @db.Decimal(12, 2)
  issueDate              DateTime      @default(now())
  dueDate                DateTime?
  paidAt                 DateTime?
  stripeCheckoutSessionId String?
  recurringInvoiceId     String?
  recurringInvoice       RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  items                  InvoiceItem[]
  payments               Payment[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status, createdAt])
}

model RecurringInvoice {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  name           String
  status         String    @default("active")
  interval       String    @default("monthly")
  currency       String    @default("CAD")
  marketRegion   String    @default("CA-QC")
  itemsJson      Json
  nextRunAt      DateTime
  lastRunAt      DateTime?
  invoices       Invoice[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId, status, nextRunAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  unit        String?
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
}

model Payment {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId             String?
  invoice               Invoice? @relation(fields: [invoiceId], references: [id])
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("CAD")
  status                String   @default("pending")
  method                String?
  stripeSessionId       String?
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())

  @@index([companyId, createdAt])
}

model Project {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  name       String
  status     String   @default("planned")
  progress   Int      @default(0)
  budget     Decimal  @default(0) @db.Decimal(12, 2)
  dueDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tasks      Task[]

  @@index([companyId, status])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  status      String    @default("todo")
  priority    String    @default("medium")
  assigneeName String?
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, status])
}

model Folder {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  documents Document[]
  createdAt DateTime   @default(now())

  @@index([companyId])
}

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  name      String
  type      String?
  sizeBytes Int      @default(0)
  storageKey String?
  tags      String[] @default([])
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
}

model Automation {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  trigger   String
  active    Boolean  @default(true)
  definition Json?
  runs      Int      @default(0)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, active])
}

model ChatThread {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([companyId])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolName  String?
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorId   String?
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, readAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId])
}

model JobSite {
  id         String      @id @default(cuid())
  companyId  String
  name       String
  address    String?
  clientName String?
  lat        Float
  lng        Float
  radiusM    Int         @default(150)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  timeEntries TimeEntry[]

  @@index([companyId])
}

model ConstructionWorkspace {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConstructionJob {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number         String
  name           String
  clientName     String
  address        String
  city           String
  province       String   @default("QC")
  status         String
  contractValue  Decimal  @default(0) @db.Decimal(14, 2)
  budgetCost     Decimal  @default(0) @db.Decimal(14, 2)
  actualCost     Decimal  @default(0) @db.Decimal(14, 2)
  progressPct    Int      @default(0)
  holdbackPct    Int      @default(10)
  startDate      String
  endDate        String?
  superintendent String
  trades         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status])
}

model ConstructionLead {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  source        String
  projectType   String
  valueEstimate Decimal  @default(0) @db.Decimal(14, 2)
  stage         String
  owner         String
  city          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, stage])
}

model ConstructionEstimate {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number     String
  jobId      String?
  clientName String
  title      String
  status     String
  subtotal   Decimal  @default(0) @db.Decimal(14, 2)
  tps        Decimal  @default(0) @db.Decimal(14, 2)
  tvq        Decimal  @default(0) @db.Decimal(14, 2)
  total      Decimal  @default(0) @db.Decimal(14, 2)
  validUntil String
  linesJson  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status])
}

model ConstructionChangeOrder {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number      String
  jobId       String
  jobName     String
  title       String
  reason      String
  amount      Decimal  @default(0) @db.Decimal(14, 2)
  status      String
  submittedAt String?
  approvedAt  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, number])
  @@index([companyId, jobId])
}

model ConstructionProgressInvoice {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId         String
  jobName       String
  number        String
  periodLabel   String
  completionPct Int      @default(0)
  amount        Decimal  @default(0) @db.Decimal(14, 2)
  holdback      Decimal  @default(0) @db.Decimal(14, 2)
  netDue        Decimal  @default(0) @db.Decimal(14, 2)
  status        String
  dueDate       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, number])
  @@index([companyId, jobId])
}

model ConstructionCcqWorker {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                  String
  trade                 String
  competency            String
  ccqNumber             String
  cardExpires           String
  hoursThisPeriod       Decimal  @default(0) @db.Decimal(8, 2)
  apprenticeshipRatioOk Boolean  @default(true)
  trainingDue           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
}

model ConstructionCcqDeclaration {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workerId   String
  workerName String
  jobId      String
  jobName    String
  trade      String
  weekEnding String
  hours      Decimal  @default(0) @db.Decimal(8, 2)
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, weekEnding])
}

model ConstructionMarketingCampaign {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  channel   String
  status    String
  spend     Decimal  @default(0) @db.Decimal(14, 2)
  leads     Int      @default(0)
  contracts Int      @default(0)
  revenue   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
}

model EmployeeProfile {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?
  name          String
  email         String
  role          Role        @default(EMPLOYEE)
  jobTitle      String?
  hourlyRate    Decimal     @default(0) @db.Decimal(10, 2)
  overtimeRate  Decimal     @default(0) @db.Decimal(10, 2)
  status        String      @default("active")
  phone         String?
  sinNumber     String?
  sinMasked     String?
  dateOfBirth   DateTime?
  hireDate      DateTime?
  contractType  String      @default("full_time")
  addressLine1  String?
  addressLine2  String?
  city          String?
  province      String?     @default("QC")
  postalCode    String?
  country       String?     @default("CA")
  emergencyName String?
  emergencyPhone String?
  notes         String?
  payrollTaxJson Json?
  dossierComplete Boolean   @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  timeEntries   TimeEntry[]
  payslips      Payslip[]

  @@index([companyId, status])
  @@index([companyId, email])
}

model TimeEntry {
  id                 String   @id @default(cuid())
  companyId          String
  employeeId         String
  employee           EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobSiteId          String?
  jobSite            JobSite? @relation(fields: [jobSiteId], references: [id])
  clockInAt          DateTime
  clockOutAt         DateTime?
  clockInLat         Float?
  clockInLng         Float?
  clockOutLat        Float?
  clockOutLng        Float?
  withinGeofence     Boolean  @default(true)
  distanceFromSiteM  Int?
  breakMinutes       Int      @default(0)
  pauseStartedAt     DateTime?
  totalPauseMs       Int      @default(0)
  hoursWorked        Decimal? @db.Decimal(8, 2)
  status             String   @default("clocked_in")
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId, employeeId, clockInAt])
  @@index([status])
}

model Payslip {
  id             String   @id @default(cuid())
  companyId      String
  employeeId     String
  employee       EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  regularHours   Decimal  @default(0) @db.Decimal(8, 2)
  overtimeHours  Decimal  @default(0) @db.Decimal(8, 2)
  grossPay       Decimal  @default(0) @db.Decimal(12, 2)
  netPay         Decimal  @default(0) @db.Decimal(12, 2)
  linesJson      Json?
  status         String   @default("draft")
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([companyId, employeeId, periodStart])
}

model LedgerAccount {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  type      String
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
}

model JournalEntry {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime
  memo          String
  reference     String?
  debitAccount  String
  creditAccount String
  amount        Decimal  @db.Decimal(14, 2)
  taxCode       String?
  taxAmount     Decimal? @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  @@index([companyId, date])
}

model TeamChannel {
  id            String              @id @default(cuid())
  companyId     String
  name          String
  description   String?
  type          String              @default("company")
  encrypted     Boolean             @default(true)
  allowedRoles  String[]            @default([])
  createdById   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  messages      TeamChatMessage[]
  members       TeamChannelMember[]

  @@index([companyId])
}

model TeamChatMessage {
  id          String               @id @default(cuid())
  channelId   String
  channel     TeamChannel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId    String?
  senderName  String
  body        String
  encrypted   Boolean              @default(true)
  createdAt   DateTime             @default(now())
  attachments TeamChatAttachment[]

  @@index([channelId, createdAt])
}

model TeamChannelMember {
  id        String      @id @default(cuid())
  channelId String
  channel   TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String?
  email     String
  role      Role?
  createdAt DateTime    @default(now())

  @@unique([channelId, email])
  @@index([email])
}

model TeamChatAttachment {
  id          String          @id @default(cuid())
  messageId   String
  message     TeamChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  name        String
  mimeType    String
  sizeBytes   Int             @default(0)
  storageKey  String
  url         String
  createdAt   DateTime        @default(now())

  @@index([messageId])
}

// Meetings and live streaming (Daily.co)
model Meeting {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title         String
  audience      String        @default("company")
  slug          String
  dailyRoomName String
  dailyRoomUrl  String
  status        String        @default("scheduled")
  hostUserId    String?
  hostName      String?
  startsAt      DateTime?
  endsAt        DateTime?
  allowedRoles  String[]      @default([])
  clientIds     String[]      @default([])
  shareToken    String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  liveSessions  LiveSession[]

  @@unique([companyId, slug])
  @@index([companyId, createdAt])
  @@index([companyId, audience])
  @@index([slug])
}

model LiveSession {
  id            String     @id @default(cuid())
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  meetingId     String?
  meeting       Meeting?   @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  title         String?
  dailyRoomName String
  dailyRoomUrl  String
  status        String     @default("scheduled")
  audience      String     @default("company")
  slug          String
  shareToken    String     @unique @default(cuid())
  startedAt     DateTime?
  endedAt       DateTime?
  recordingUrl  String?
  clientIds     String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  posts         FeedPost[]

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([slug])
}

model FeedPost {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId        String?
  authorName      String
  body            String
  audience        String       @default("company")
  liveSessionId   String?
  liveSession     LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  recordingUrl    String?
  visibilityRoles String[]     @default([])
  clientIds       String[]     @default([])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, audience])
}

// Employee deletion requests — admin must approve sensitive deletes
model DeleteRequest {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  resourceType String
  resourceId   String
  resourceLabel String?
  reason       String?
  status       String    @default("pending")
  requestedByEmail String
  requestedByName  String?
  reviewedByEmail  String?
  reviewedAt       DateTime?
  reviewNote       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, resourceType, resourceId])
}

// Company backup metadata (payload stored in Netlify Blobs)
model CompanyBackup {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label       String
  storageKey  String?
  sizeBytes   Int      @default(0)
  status      String   @default("ready")
  trigger     String   @default("auto")
  createdByEmail String?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
}
