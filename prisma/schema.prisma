generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  PROJECT_MANAGER
  SITE_SUPERVISOR
  FOREMAN
  FIELD_WORKER
  ESTIMATOR
  ACCOUNTANT
  PAYROLL_CLERK
  SAFETY_OFFICER
  HR_MANAGER
  PROCUREMENT
  OFFICE_ADMIN
  MANAGER
  EMPLOYEE
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum Plan {
  starter
  growth
  business
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  email              String?
  phone              String?
  website            String?
  plan               Plan               @default(starter)
  subscriptionStatus SubscriptionStatus @default(trialing)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  trialEndsAt        DateTime?
  enabledModules     String[]           @default([])
  brandingPrimary    String             @default("#004F6E")
  brandingAccent     String             @default("#D4AF37")
  logoUrl            String?
  emailFrom          String?
  inboxEmail         String?
  emailSenderName    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  invitations        Invitation[]
  clients            Client[]
  leads              Lead[]
  deals              Deal[]
  quotes             Quote[]
  invoices           Invoice[]
  payments           Payment[]
  projects           Project[]
  documents          Document[]
  folders            Folder[]
  automations        Automation[]
  chatThreads        ChatThread[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  emailMessages      EmailMessage[]
}

model User {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String    @unique
  emailVerified DateTime?
  passwordHash String?
  role         Role      @default(EMPLOYEE)
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  accounts     Account[]

  @@index([companyId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?

  @@unique([provider, providerAccountId])
}

model Invitation {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email     String
  role      Role     @default(EMPLOYEE)
  token     String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Client {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  phone         String?
  status        String   @default("lead")
  tags          String[] @default([])
  city          String?
  industry      String?
  ownerName     String?
  lifetimeValue Decimal  @default(0) @db.Decimal(12, 2)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quotes        Quote[]
  invoices      Invoice[]
  projects      Project[]
  emailMessages EmailMessage[]

  @@index([companyId, status, createdAt])
}

model EmailMessage {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  direction  String   @default("outbound")
  fromEmail  String
  toEmail    String
  subject    String
  bodyText   String?
  bodyHtml   String?
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  quoteId    String?
  invoiceId  String?
  providerId String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, clientId])
  @@index([companyId, direction])
}

model Lead {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  source    String?
  status    String   @default("new")
  score     Int      @default(0)
  ownerName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
}

model Deal {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title      String
  clientName String?
  value      Decimal  @default(0) @db.Decimal(12, 2)
  stage      String   @default("new")
  ownerName  String?
  closeDate  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, stage])
}

model Quote {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?     @relation(fields: [clientId], references: [id])
  number     String
  status     String      @default("draft")
  currency   String      @default("CAD")
  subtotal   Decimal     @default(0) @db.Decimal(12, 2)
  tax        Decimal     @default(0) @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @default(0) @db.Decimal(12, 2)
  issueDate  DateTime    @default(now())
  validUntil DateTime?
  items      QuoteItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
}

model Invoice {
  id                     String        @id @default(cuid())
  companyId              String
  company                Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId               String?
  client                 Client?       @relation(fields: [clientId], references: [id])
  number                 String
  status                 String        @default("draft")
  currency               String        @default("CAD")
  subtotal               Decimal       @default(0) @db.Decimal(12, 2)
  tax                    Decimal       @default(0) @db.Decimal(12, 2)
  discount               Decimal       @default(0) @db.Decimal(12, 2)
  total                  Decimal       @default(0) @db.Decimal(12, 2)
  issueDate              DateTime      @default(now())
  dueDate                DateTime?
  paidAt                 DateTime?
  stripeCheckoutSessionId String?
  recurringInvoiceId     String?
  items                  InvoiceItem[]
  payments               Payment[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([companyId, number])
  @@index([companyId, status, createdAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
}

model Payment {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId             String?
  invoice               Invoice? @relation(fields: [invoiceId], references: [id])
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("CAD")
  status                String   @default("pending")
  method                String?
  stripeSessionId       String?
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())

  @@index([companyId, createdAt])
}

model Project {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id])
  name       String
  status     String   @default("planned")
  progress   Int      @default(0)
  budget     Decimal  @default(0) @db.Decimal(12, 2)
  dueDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tasks      Task[]

  @@index([companyId, status])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  status      String    @default("todo")
  priority    String    @default("medium")
  assigneeName String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, status])
}

model Folder {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  documents Document[]
  createdAt DateTime   @default(now())

  @@index([companyId])
}

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  name      String
  type      String?
  sizeBytes Int      @default(0)
  storageKey String?
  tags      String[] @default([])
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
}

model Automation {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  trigger   String
  active    Boolean  @default(true)
  definition Json?
  runs      Int      @default(0)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, active])
}

model ChatThread {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([companyId])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolName  String?
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorId   String?
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId])
}

model JobSite {
  id         String      @id @default(cuid())
  companyId  String
  name       String
  address    String?
  clientName String?
  lat        Float
  lng        Float
  radiusM    Int         @default(150)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  timeEntries TimeEntry[]

  @@index([companyId])
}

model EmployeeProfile {
  id            String      @id @default(cuid())
  companyId     String
  userId        String?
  name          String
  email         String
  role          Role        @default(EMPLOYEE)
  jobTitle      String?
  hourlyRate    Decimal     @default(0) @db.Decimal(10, 2)
  overtimeRate  Decimal     @default(0) @db.Decimal(10, 2)
  status        String      @default("active")
  phone         String?
  sinMasked     String?
  hireDate      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  timeEntries   TimeEntry[]
  payslips      Payslip[]

  @@index([companyId, status])
}

model TimeEntry {
  id                 String   @id @default(cuid())
  companyId          String
  employeeId         String
  employee           EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobSiteId          String?
  jobSite            JobSite? @relation(fields: [jobSiteId], references: [id])
  clockInAt          DateTime
  clockOutAt         DateTime?
  clockInLat         Float?
  clockInLng         Float?
  clockOutLat        Float?
  clockOutLng        Float?
  withinGeofence     Boolean  @default(true)
  distanceFromSiteM  Int?
  breakMinutes       Int      @default(0)
  hoursWorked        Decimal? @db.Decimal(8, 2)
  status             String   @default("clocked_in")
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId, employeeId, clockInAt])
  @@index([status])
}

model Payslip {
  id             String   @id @default(cuid())
  companyId      String
  employeeId     String
  employee       EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  regularHours   Decimal  @default(0) @db.Decimal(8, 2)
  overtimeHours  Decimal  @default(0) @db.Decimal(8, 2)
  grossPay       Decimal  @default(0) @db.Decimal(12, 2)
  netPay         Decimal  @default(0) @db.Decimal(12, 2)
  linesJson      Json?
  status         String   @default("draft")
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([companyId, employeeId, periodStart])
}

model LedgerAccount {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  type      String
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
}

model JournalEntry {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime
  memo          String
  reference     String?
  debitAccount  String
  creditAccount String
  amount        Decimal  @db.Decimal(14, 2)
  taxCode       String?
  taxAmount     Decimal? @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  @@index([companyId, date])
}

model TeamChannel {
  id        String            @id @default(cuid())
  companyId String
  name      String
  type      String            @default("company")
  encrypted Boolean           @default(true)
  createdAt DateTime          @default(now())
  messages  TeamChatMessage[]

  @@index([companyId])
}

model TeamChatMessage {
  id         String      @id @default(cuid())
  channelId  String
  channel    TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId   String?
  senderName String
  body       String
  encrypted  Boolean     @default(true)
  createdAt  DateTime    @default(now())

  @@index([channelId, createdAt])
}
