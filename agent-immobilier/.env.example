# Copier vers .env (local) — ne jamais committer de vrais secrets.
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_SITE_URL=https://leonnebienaime.ca

# Local: valeurs de développement OK.
# Production Cloudflare: OBLIGATOIRE via:
#   npx wrangler secret put ADMIN_PASSWORD
#   npx wrangler secret put ADMIN_SECRET
# ADMIN_SECRET doit faire au moins 16 caractères (idéalement 32+ aléatoires).
# Sert aussi à signer les URLs /api/media et les sessions HMAC.
ADMIN_PASSWORD=
ADMIN_SECRET=
