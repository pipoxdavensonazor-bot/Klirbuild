{
  "name": "klirline-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/cloudflare-build.mjs",
    "build:netlify": "node scripts/netlify-build.mjs",
    "cf:copy-prisma-wasm": "node scripts/copy-prisma-wasm.mjs",
    "preview": "opennextjs-cloudflare build && npm run cf:copy-prisma-wasm && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && npm run cf:copy-prisma-wasm && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && npm run cf:copy-prisma-wasm && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv types/cloudflare-env.d.ts --include-runtime false",
    "cf:provision": "node scripts/cloudflare-provision.mjs",
    "cf:secrets": "node scripts/cloudflare-secrets.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-admin": "tsx scripts/seed-platform-admin.ts",
    "stripe:setup": "tsx scripts/stripe-setup.ts",
    "stripe:verify": "tsx scripts/stripe-verify.ts",
    "production:verify": "tsx scripts/production-verify.ts",
    "smoke:test": "tsx scripts/smoke-test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "security:check": "node scripts/security-check.mjs",
    "amplify:fix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/aws-amplify-fix.ps1",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "android:sync": "npm --prefix apps/android run sync",
    "android:open": "npm --prefix apps/android run open",
    "android:release": "npm --prefix apps/android run sync && npm --prefix apps/android run build:release",
    "play:upload": "node scripts/play-upload.mjs",
    "play:publish": "npm run android:release && PLAY_AAB_PATH=apps/android/android/app/build/outputs/bundle/release/app-release.aab npm run play:upload",
    "stripe:provision": "node scripts/stripe-provision-prod.mjs",
    "ios:sync": "npm --prefix apps/ios run sync"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.2",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.24.0",
    "next": "^15.5.20",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20",
    "googleapis": "^173.0.0",
    "postcss": "^8.5.19",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.7",
    "wrangler": "^4.113.0"
  }
}
